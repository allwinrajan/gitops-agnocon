<configuration name="xml_curl.conf" description="cURL XML Gateway">

  <bindings>

    <binding name="directory">
      <param name="gateway-url" value="DIRECTORY_URL_PLACEHOLDER" bindings="directory"/>
    </binding>

    <binding name="dialplan">
      <param name="gateway-url" value="ROUTING_ENGINE_URL_PLACEHOLDER" bindings="dialplan"/>
    </binding>

  </bindings>

</configuration>
